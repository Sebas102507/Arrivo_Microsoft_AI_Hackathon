# Generated automatically by scripts/deploy.sh — or fill in manually from the Azure portal
AZURE_OPENAI_ENDPOINT=https://<your-foundry>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<key>
AZURE_SEARCH_INDEX=arrivo-kb

# Microsoft Foundry Agent Service (v2 agents grounded on arrivo-kb)
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry>.services.ai.azure.com/api/projects/arrivo-project
FOUNDRY_SEARCH_CONNECTION_NAME=arrivosearch
# Optional: simple|semantic|vector|vector_simple_hybrid|vector_semantic_hybrid (default: simple)
FOUNDRY_SEARCH_QUERY_TYPE=simple

# Written by `python foundry/create_v2.py` (add --team for the orchestrator + specialists).
# Set FOUNDRY_USE_TEAM=1 so /api/chat routes through all specialists + orchestrator.
FOUNDRY_USE_TEAM=1
# Set ARRIVO_USE_EVALUATOR=1 to add a reflection pass on grounded answers (slower).
ARRIVO_USE_EVALUATOR=
FOUNDRY_V2_AGENT_NAME=
FOUNDRY_V2_EVALUATOR_NAME=
FOUNDRY_V2_ORCHESTRATOR_NAME=
FOUNDRY_V2_SPECIALIST_NAMES={}
